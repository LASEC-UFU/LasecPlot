{
  "name": "lasecplot",
  "description": "Telemetry viewer.",
  "version": "1.5.2",
  "publisher": "josuemoraisgh",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/josuemoraisgh/LasecPlot"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:lasecplot.start"
  ],
  "main": "./out/extension.js",
  "icon": "images/logo-color.png",
  "contributes": {
    "commands": [
      {
        "command": "lasecplot.start",
        "title": "Start LasecPlot session",
        "category": "lasecplot",
        "icon": {
          "light": "images/logo-color.svg",
          "dark": "images/logo-color.svg"
        }
      }
    ],
	"configuration": {
		"title": "LasecPlot",
		"properties": {
			"lasecplot.udpPort": {
				"type": "number",
				"default": 47269,
				"description": "Porta UDP local (LP) para dados."
			}
		}
	}
},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test:unit": "npm run compile && node --test out/test/lasecsimulSourceProvider.test.js",
    "test:package": "npm run compile && node --test out/test/packaging.test.js",
    "lint": "eslint . --ext .ts",
    "watch": "tsc -w -p ./",
    "test": "npm run test:unit && npm run test:package",
    "prepackage": "node scripts/prune-foreign-prebuilds.js",
    "package": "vsce package --target win32-x64",
    "publish": "vsce publish --target win32-x64"
  },
  "dependencies": {
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.94.0",
    "@types/vscode-webview": "^1.57.0",
    "@typescript-eslint/eslint-plugin": "^8.11.0",
    "@typescript-eslint/parser": "^8.11.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.3",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.1.0"
  },
  "files": [
    "out",
    "media",
    "images",
    "node_modules",
    "README.md",
    "LICENSE.txt",
    "package.json"
  ]
}
